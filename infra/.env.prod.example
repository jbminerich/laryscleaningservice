APP_DOMAIN=laryscleaningservices.org

# GHCR image tags (set by CI/CD or edit manually)
FRONTEND_IMAGE=ghcr.io/jbminerich/laryscleaningservice-frontend:latest

# Admin authentication (change before production use)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-password
ADMIN_SESSION_HOURS=12
# Optional legacy static admin token fallback (can leave as-is or change)
ADMIN_TOKEN=change-me-admin-token

# Appointment email notifications
APPOINTMENT_NOTIFICATION_TO=ilariellysilva02@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password-or-app-password
SMTP_FROM_EMAIL=your-sender-email@example.com
SMTP_USE_TLS=true

# Required for Let's Encrypt
LETSENCRYPT_EMAIL=you@example.com
